# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# sentinx dev log (tailable runtime log)
dev.log

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# live-bridge transient — the Arena's ?live=1 source is a volatile per-turn run mirror, NOT a fixture
/public/runs/live.json
/public/runs/*.tmp
