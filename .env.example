# AutoSentinx POC — environment template. Copy to .env and fill in. NEVER commit the real .env.

# --- Our platform DB (Neon Postgres) ---
REGSENTINEL_DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME

# --- Target under test (AARAV) ---
AARAV_BASE_URL=http://127.0.0.1:8001
AARAV_DEFAULT_CONTACT_ID=1
AARAV_CARD_SHARED_SECRET=        # must match the target's signed agent-card secret
AARAV_CARD_KEY_ID=               # must match the target's agent-card key id
TARGET_BEARER_TOKEN=             # optional; only if the target requires a bearer token
AARAV_FORCE_CURRENT_TIME=12:00   # forces the target's settings-aware contact-window path

# --- LLM provider + models (swappable: change these to switch the whole stack) ---
# provider: gemini | vertex | anthropic-vertex | anthropic | openai-compat   (blank → inferred from model name)
# The attacker, the classifier, and each judge each resolve their own (provider, model) — change any one
# in isolation. openai-compat = a self-hosted open model behind an OpenAI-compatible API (see OPENAI_* below).
LLM_PROVIDER=gemini
LLM_ATTACKER_MODEL=gemini-2.5-flash
LLM_JUDGE_MODEL=gemini-2.5-pro
# In-call classifier — its own swappable provider+model (blank provider → uses LLM_PROVIDER).
LLM_CLASSIFIER_PROVIDER=gemini
LLM_CLASSIFIER_MODEL=gemini-2.5-flash
# Phase-2 verdict panel (comma-sep provider:model), each resolved independently. A judge that errors
# (e.g. Claude without Vertex quota) is dropped; strict majority is taken over the survivors.
# 3rd judge is Gemini for now (free); for cross-vendor diversity swap it to
# anthropic-vertex:claude-sonnet-4@20250514  or  openai-compat:<your-open-model>.
LLM_JUDGE_MODELS=gemini:gemini-2.5-pro,gemini:gemini-2.5-flash,gemini:gemini-2.5-flash-lite

# Gemini Developer API (provider=gemini)
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Google Cloud / Vertex (provider=vertex for Gemini, anthropic-vertex for Claude)
VERTEX_PROJECT_ID=your-gcp-project
VERTEX_LOCATION=global
ANTHROPIC_VERTEX_REGION=global   # claude-sonnet-4@20250514 is served from `global` (needs Vertex quota >0)
# e.g. to run Claude on Google Cloud:
#   LLM_PROVIDER=anthropic-vertex
#   LLM_ATTACKER_MODEL=claude-sonnet-4@20250514

# Anthropic direct API (provider=anthropic) — optional
# ANTHROPIC_API_KEY=

# Self-hosted open model behind an OpenAI-compatible API (provider=openai-compat | self-hosted | vllm | ollama)
# OPENAI_BASE_URL=http://localhost:8000/v1   # e.g. vLLM/TGI/Ollama serving meta-llama/Llama-3.1-70B-Instruct
# OPENAI_API_KEY=                            # optional for most self-hosted servers

# --- Run tuning ---
MAX_TURNS=8
